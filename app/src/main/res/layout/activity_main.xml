<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/camera_container"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_dark">

    <!-- Full-screen camera preview -->
    <androidx.camera.view.PreviewView
        android:id="@+id/view_finder"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:scaleType="fillStart"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- Bounding box overlay -->
    <com.rahul.yolov8tflite.OverlayView
        android:id="@+id/overlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:translationZ="5dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- Top status bar -->
    <LinearLayout
        android:id="@+id/topBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_top_bar"
        android:orientation="horizontal"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:paddingTop="16dp"
        android:paddingBottom="20dp"
        android:gravity="center_vertical"
        android:translationZ="10dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <View
            android:layout_width="10dp"
            android:layout_height="10dp"
            android:background="@drawable/bg_mode_button_active"
            android:layout_marginEnd="10dp" />

        <TextView
            android:id="@+id/appTitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/app_name"
            android:textColor="@color/text_primary"
            android:textSize="20sp"
            android:textStyle="bold"
            android:letterSpacing="0.05" />

        <View
            android:id="@+id/speakingDot"
            android:layout_width="8dp"
            android:layout_height="8dp"
            android:background="@drawable/bg_mode_button_active"
            android:layout_marginEnd="6dp"
            android:visibility="invisible" />

        <TextView
            android:id="@+id/inferenceTime"
            tools:text="34ms"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/accent_green"
            android:textSize="13sp"
            android:fontFamily="monospace" />

    </LinearLayout>

    <!-- Direction view - shown in walking mode -->
    <com.rahul.yolov8tflite.DirectionView
        android:id="@+id/directionView"
        android:layout_width="160dp"
        android:layout_height="160dp"
        android:visibility="gone"
        android:translationZ="8dp"
        app:layout_constraintBottom_toTopOf="@id/guidanceText"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/topBar"
        app:layout_constraintVertical_bias="0.65" />

    <!-- Guidance text overlay -->
    <TextView
        android:id="@+id/guidanceText"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="24dp"
        android:layout_marginEnd="24dp"
        android:layout_marginBottom="12dp"
        android:background="@drawable/bg_guidance_default"
        android:gravity="center"
        android:padding="14dp"
        android:textColor="@color/text_primary"
        android:textSize="15sp"
        android:textStyle="bold"
        android:lineSpacingExtra="4dp"
        android:visibility="gone"
        android:translationZ="8dp"
        tools:text="Path is clear. Walk forward."
        app:layout_constraintBottom_toTopOf="@id/controlCard"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <!-- Bottom control card -->
    <LinearLayout
        android:id="@+id/controlCard"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_control_card"
        android:orientation="vertical"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:paddingTop="20dp"
        android:paddingBottom="28dp"
        android:translationZ="12dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- Pull handle -->
        <View
            android:layout_width="40dp"
            android:layout_height="4dp"
            android:background="#334A90E2"
            android:layout_gravity="center_horizontal"
            android:layout_marginBottom="16dp" />

        <!-- Mode label -->
        <TextView
            android:id="@+id/modeLabel"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/select_mode"
            android:textColor="@color/text_secondary"
            android:textSize="11sp"
            android:letterSpacing="0.12"
            android:textAllCaps="true"
            android:gravity="center"
            android:layout_marginBottom="14dp" />

        <!-- Three mode buttons -->
        <LinearLayout
            android:id="@+id/buttonsRow"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center">

            <!-- Read Text / OCR -->
            <LinearLayout
                android:id="@+id/ocrButton"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginEnd="6dp"
                android:background="@drawable/bg_mode_button"
                android:gravity="center"
                android:orientation="vertical"
                android:padding="14dp"
                android:clickable="true"
                android:focusable="true">

                <ImageView
                    android:id="@+id/ocrIcon"
                    android:layout_width="26dp"
                    android:layout_height="26dp"
                    android:src="@drawable/ic_text_scan"
                    android:importantForAccessibility="no" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/read_text"
                    android:textColor="@color/text_primary"
                    android:textSize="11sp"
                    android:layout_marginTop="6dp"
                    android:gravity="center" />

            </LinearLayout>

            <!-- Detect Objects -->
            <LinearLayout
                android:id="@+id/detectButton"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="6dp"
                android:layout_marginEnd="6dp"
                android:background="@drawable/bg_mode_button"
                android:gravity="center"
                android:orientation="vertical"
                android:padding="14dp"
                android:clickable="true"
                android:focusable="true">

                <ImageView
                    android:id="@+id/detectIcon"
                    android:layout_width="26dp"
                    android:layout_height="26dp"
                    android:src="@drawable/ic_detect"
                    android:importantForAccessibility="no" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/detect_objects"
                    android:textColor="@color/text_primary"
                    android:textSize="11sp"
                    android:layout_marginTop="6dp"
                    android:gravity="center" />

            </LinearLayout>

            <!-- Walking / Navigation -->
            <LinearLayout
                android:id="@+id/walkButton"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="6dp"
                android:background="@drawable/bg_mode_button"
                android:gravity="center"
                android:orientation="vertical"
                android:padding="14dp"
                android:clickable="true"
                android:focusable="true">

                <ImageView
                    android:id="@+id/walkIcon"
                    android:layout_width="26dp"
                    android:layout_height="26dp"
                    android:src="@drawable/ic_walk"
                    android:importantForAccessibility="no" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/walking_mode"
                    android:textColor="@color/text_primary"
                    android:textSize="11sp"
                    android:layout_marginTop="6dp"
                    android:gravity="center" />

            </LinearLayout>

        </LinearLayout>

        <!-- Status text -->
        <TextView
            android:id="@+id/statusText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/status_idle"
            android:textColor="@color/text_secondary"
            android:textSize="12sp"
            android:gravity="center"
            android:layout_marginTop="14dp"
            android:lineSpacingExtra="2dp" />

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
